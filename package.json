{
  "name": "ems-front",
  "description": "Enterprise management system desktop and web client",
  "author": "Aptivora Global Solutions <support@aptivoraglobalsolutions.com>",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "vite build",
    "build:electron:main": "node scripts/build-electron.mjs",
    "build:electron": "cross-env VITE_IS_ELECTRON=true vite build && npm run build:electron:main",
    "dist:electron": "npm run build:electron && electron-builder --config electron-builder.yml",
    "electron:dev": "cross-env VITE_IS_ELECTRON=true vite",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.98.0",
    "@tanstack/react-query-devtools": "^5.98.0",
    "axios": "^1.13.5",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "ogl": "^1.0.11",
    "playwright": "^1.58.2",
    "postprocessing": "^6.39.0",
    "react": "^19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "three": "^0.183.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1"
  }
}
